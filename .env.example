# Copia este archivo a ".env" y cambia los valores antes de levantar en el VPS:
#   cp .env.example .env
# docker compose lee automaticamente este .env para rellenar los secretos.

# Secreto para firmar las sesiones (usa algo largo y aleatorio).
# Puedes generar uno con:  openssl rand -base64 32
NEXTAUTH_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# Credenciales del administrador (quien agrega recetas)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=recetas123
